# ----------------------------------------------------------------------
# Prevent directory browsing
# ----------------------------------------------------------------------
Options -Indexes
# Users cannot see a list of files if no index exists

# ----------------------------------------------------------------------
# Enable URL rewriting
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /curd/

    # ------------------------------------------------------------------
    # Redirect www to non-www (optional)
    # ------------------------------------------------------------------
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

    # ------------------------------------------------------------------
    # Remove index.php from URL
    # ------------------------------------------------------------------
    RewriteCond %{REQUEST_URI} ^system.*
    RewriteRule ^(.*)$ /index.php/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php/$1 [L,QSA]

    # ------------------------------------------------------------------
    # Optional: remove trailing slashes from URLs
    # ------------------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ------------------------------------------------------------------
    # Pass Authorization headers (for APIs)
    # ------------------------------------------------------------------
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# ----------------------------------------------------------------------
# Fallback if mod_rewrite is not enabled
# ----------------------------------------------------------------------
<IfModule !mod_rewrite.c>
    ErrorDocument 404 index.php
</IfModule>

# ----------------------------------------------------------------------
# Disable server signature (optional security)
# ----------------------------------------------------------------------
ServerSignature Off